# Скопируйте этот файл в .env и заполните значения.

# Секретный ключ Django (для продакшена сгенерируйте новый).
DJANGO_SECRET_KEY=change-me-in-production

# 1 — режим разработки (DEBUG=True), 0 — продакшен.
DJANGO_DEBUG=1

# Разрешённые хосты через запятую (для продакшена).
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Источники, которым разрешён доступ к API (адрес фронта на Vite).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Доверенные origin для CSRF — нужно для входа в админку через https-туннель.
# Пример: CSRF_TRUSTED_ORIGINS=https://xxxx.trycloudflare.com
CSRF_TRUSTED_ORIGINS=
